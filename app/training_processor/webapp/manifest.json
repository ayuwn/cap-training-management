{
    "_version": "1.32.0",
    "sap.app": {
        "id": "sap.fe.cap.training",
        "type": "application",
        "title": "{{title}}",
        "description": "{{description}}",
        "i18n": {
            "bundleName": "sap.fe.cap.training.i18n.i18n",
            "supportedLocales": [
                "en",
                "de",
                "fr"
            ],
            "fallbackLocale": "en"
        },
        "applicationVersion": {
            "version": "1.0.0"
        },
        "dataSources": {
            "mainService": {
                "uri": "/processor/",
                "type": "OData",
                "settings": {
                    "odataVersion": "4.0"
                }
            }
        },
        "offline": false,
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "ui5template.fiorielements.v4.lrop",
            "version": "1.0.0"
        },
        "crossNavigation": {
            "inbounds": {
                "travel-inbound": {
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    },
                    "semanticObject": "training",
                    "action": "process",
                    "title": "Process Training",
                    "subTitle": "Process training",
                    "icon": "sap-icon://flight"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "sap-icon://flight",
            "favIcon": "sap-icon://flight",
            "phone": "sap-icon://flight",
            "phone@2": "sap-icon://flight",
            "tablet": "sap-icon://flight",
            "tablet@2": "sap-icon://flight"
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "resources": {
            "js": [],
            "css": []
        },
        "dependencies": {
            "minUI5Version": "1.139.0",
            "libs": {
                "sap.ui.core": {},
                "sap.fe.templates": {}
            }
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "sap.fe.cap.training.i18n.i18n",
                    "supportedLocales": [
                        "en",
                        "de",
                        "fr"
                    ],
                    "fallbackLocale": "en"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            },
            "@i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "uri": "i18n/i18n.properties"
            }
        },
        "routing": {
            "routes": [
                {
                "pattern": ":?query:",
                "name": "TrainingRequestList",
                "target": "TrainingRequestList"
                },
                {
                "pattern": "TrainingRequest({key}):?query:",
                "name": "TrainingRequestObjectPage",
                "target": "TrainingRequestObjectPage"
                }
            ],
            "targets": {
                "TrainingRequestList": {
                "type": "Component",
                "id": "TrainingRequestList",
                "name": "sap.fe.templates.ListReport",
                "options": {
                    "settings": {
                    "entitySet": "TrainingRequest",
                    "filterSettings": {
                        "showDraftEditState": false
                    },
                    "controlConfiguration": {
                        "@com.sap.vocabularies.UI.v1.LineItem": {
                            "tableSettings": {
                                "type": "ResponsiveTable",
                                "personalization": {
                                "column": false,
                                "sort": true,
                                "filter": true
                                }
                            }
                        },
                        "@com.sap.vocabularies.UI.v1.SelectionFields": {
                            "useSemanticDateRange": true,
                            "disableDraftEditStateFilter": true
                        }
                    },
                    "variantManagement": "Page",
                    "initialLoad": "Enabled",
                    "navigation": {
                        "TrainingRequest": {
                        "detail": {
                            "route": "TrainingRequestObjectPage"
                        }
                        }
                    }
                    }
                }
                },
                "TrainingRequestObjectPage": {
                "type": "Component",
                "id": "TrainingRequestObjectPage",
                "name": "sap.fe.templates.ObjectPage",
                "options": {
                    "settings": {
                    "entitySet": "TrainingRequest",
                    "editableHeaderContent": false
                    }
                }
                }
            },
            "config": {}
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "extends": {
            "extensions": {
                "sap.ui.controllerExtensions": {
                "sap.fe.templates.ListReport.ListReportController": {
                    "controllerName": "sap.fe.cap.training.ext.controller.ListReportExt"
                }
                }
            }
        }
    },
    "sap.platform.abap": {
        "_version": "1.1.0",
        "uri": ""
    },
    "sap.platform.hcp": {
        "_version": "1.1.0",
        "uri": ""
    },
    "sap.fiori": {
        "_version": "1.1.0",
        "registrationIds": [],
        "archeType": "transactional"
    },
    "sap.cloud": {
        "public": true,
        "service": "sap.fe.cap.training"
    }
}
